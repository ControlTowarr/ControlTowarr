{
  "name": "ControlTowarr Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "controltowarr",
  "workspaceFolder": "/app",
  "forwardPorts": [3377, 4200],
  "postCreateCommand": "cd /app && npm run install:all",
  "customizations": {
    "vscode": {
      "extensions": [
        "Angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "editor.formatOnSave": true
      }
    }
  }
}
